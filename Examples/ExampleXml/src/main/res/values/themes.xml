<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.SiriusRatingExampleXml" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/grouped_background</item>
    </style>

    <style name="SectionCard" parent="Widget.Material3.CardView.Filled">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginHorizontal">@dimen/section_horizontal_margin</item>
        <item name="cardCornerRadius">@dimen/section_corner_radius</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/cell_background</item>
    </style>
</resources>
