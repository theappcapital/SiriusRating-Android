<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/cell_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/cell_horizontal_padding"
    android:paddingVertical="@dimen/cell_vertical_padding">

    <ImageView
        android:id="@+id/icon"
        android:layout_width="@dimen/cell_icon_size"
        android:layout_height="@dimen/cell_icon_size"
        android:layout_marginEnd="@dimen/cell_icon_spacing"
        android:importantForAccessibility="no" />

    <TextView
        android:id="@+id/label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/text_primary"
        android:textSize="16sp" />
</LinearLayout>
